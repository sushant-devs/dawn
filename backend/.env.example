APP_NAME=DAWN API

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=dawn_auth

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookies
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=localhost

# Logging
LOG_LEVEL=INFO
